# PostgreSQL 配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=jqeval
POSTGRES_USER=jqeval
POSTGRES_PASSWORD=jqeval123

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=jqeval123

# MinIO 配置 (文件存储)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=jqeval
MINIO_SECURE=false

# Milvus 配置 (向量数据库)
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_PREFIX=jqeval

# 应用配置
APP_ENV=development
APP_DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# JWT 配置
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Celery 配置
CELERY_BROKER_URL=redis://:jqeval123@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:jqeval123@localhost:6379/0

# VibeAgent 配置
# 沙箱服务地址（可选，配置后使用远程沙箱，不配置则使用本地子进程）
# SANDBOX_URL=http://localhost:8080

# OpenAI API 配置（用于 VibeAgent 槽位生成和代码生成）
OPENAI_API_URL=https://api.openai.com/v1
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini